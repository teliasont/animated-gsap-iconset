<!-- SVG code for a circle 
-->
<svg id="theCircle"

xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-icon lucide-circle">
    
    <circle cx="12" cy="12" r="10"/>

</svg>

<!-- GSAP Scripting -->
<script>
    // import GSAP
    import gsap from 'gsap';

    // animate it
    gsap.from('#theCircle circle', {
        x: -200
    });

    // Hover animations
    const circle = document.querySelector('#theCircle');

    circle.addEventListener('mouseenter', () => {
        gsap.to('#theCircle circle', {
            scale: 1.2,
            transformOrigin: 'center',
            duration: 0.3,
            ease: 'power2.out'
        });
    });

    circle.addEventListener('mouseleave', () => {
        gsap.to('#theCircle circle', {
            scale: 1,
            transformOrigin: 'center',
            duration: 0.3,
            ease: 'power2.in'
        });
    });
</script>