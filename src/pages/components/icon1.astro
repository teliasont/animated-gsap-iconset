// empty frontmatter for future use
---

<!-- Square icon from Lucide -->

<svg id="theSquare"
xmlns="http://www.w3.org/2000/svg"
width="24"
height="24"
viewBox="0 0 24 24"
fill="none"
stroke="currentColor"
stroke-width="2"
stroke-linecap="round"
stroke-linejoin="round"
class="lucide lucide-square-icon lucide-square">

    <rect width="18" height="18" x="3" y="3" rx="2"/>

</svg>

<!-- GSAP Scripting -->
<script>
    import gsap from 'gsap';

    gsap.from('#theSquare rect', {
        scale: 0,
        transformOrigin: 'center',
        duration: 0.6,
        ease: 'back.out(1.7)'
    });

    // Hover animations
    const square = document.querySelector('#theSquare');

    square.addEventListener('mouseenter', () => {
        gsap.to('#theSquare rect', {
            scale: 1.2,
            transformOrigin: 'center',
            duration: 0.3,
            ease: 'power2.out'
        });
    });

    square.addEventListener('mouseleave', () => {
        gsap.to('#theSquare rect', {
            scale: 1,
            transformOrigin: 'center',
            duration: 0.3,
            ease: 'power2.in'
        });
    });
</script>